#!/bin/bash

# SalesCRM Docker CLI Tool
# Manage SalesCRM Supabase containers

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

show_help() {
    echo -e "${BLUE}SalesCRM Docker CLI${NC}"
    echo ""
    echo "Usage: ./salescrm-cli [command]"
    echo ""
    echo "Commands:"
    echo "  start       Start all SalesCRM containers"
    echo "  stop        Stop all SalesCRM containers (with auto-restart disabled)"
    echo "  restart     Restart all SalesCRM containers"
    echo "  status      Show container status"
    echo "  logs        Show container logs"
    echo "  enable      Enable auto-restart (containers start on boot)"
    echo "  disable     Disable auto-restart (containers won't auto-start)"
    echo "  clean       Stop and remove all SalesCRM containers"
    echo "  help        Show this help message"
    echo ""
    echo "Note: Containers are started via Supabase CLI"
    echo ""
}

check_docker() {
    if ! docker info > /dev/null 2>&1; then
        echo -e "${RED}Error: Docker is not running${NC}"
        echo "Please start Docker Desktop first"
        exit 1
    fi
}

get_salescrm_containers() {
    docker ps -aq --filter "name=SalesCRM" 2>/dev/null
}

get_running_salescrm_containers() {
    docker ps -q --filter "name=SalesCRM" 2>/dev/null
}

cmd_start() {
    check_docker
    echo -e "${BLUE}Starting SalesCRM containers...${NC}"
    
    # First enable auto-restart if containers exist
    CONTAINERS=$(get_salescrm_containers)
    if [ -n "$CONTAINERS" ]; then
        docker update --restart=always $CONTAINERS 2>/dev/null
        docker start $CONTAINERS
        echo -e "${GREEN}✓ SalesCRM containers started${NC}"
    else
        echo -e "${YELLOW}No SalesCRM containers found${NC}"
        echo "To create new containers, use: supabase start"
    fi
    
    cmd_status
}

cmd_stop() {
    check_docker
    echo -e "${BLUE}Stopping SalesCRM containers...${NC}"
    
    # Disable auto-restart first
    RUNNING=$(get_running_salescrm_containers)
    if [ -n "$RUNNING" ]; then
        docker update --restart=no $RUNNING 2>/dev/null
        docker stop $RUNNING
        echo -e "${GREEN}✓ SalesCRM containers stopped${NC}"
        echo -e "${YELLOW}Auto-restart disabled - containers won't start automatically${NC}"
    else
        echo -e "${YELLOW}No running SalesCRM containers found${NC}"
    fi
}

cmd_restart() {
    cmd_stop
    sleep 2
    cmd_start
}

cmd_status() {
    check_docker
    echo -e "${BLUE}SalesCRM Container Status:${NC}"
    docker ps --filter "name=SalesCRM" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
    
    COUNT=$(docker ps -q --filter "name=SalesCRM" | wc -l)
    if [ "$COUNT" -eq 0 ]; then
        echo -e "${YELLOW}No running containers${NC}"
    else
        echo -e "${GREEN}$COUNT containers running${NC}"
    fi
}

cmd_logs() {
    check_docker
    if [ -n "$2" ]; then
        # Show logs for specific container
        docker logs --tail=100 -f "$2"
    else
        # Show logs for all SalesCRM containers
        echo -e "${BLUE}Showing logs for all SalesCRM containers (Ctrl+C to exit):${NC}"
        docker logs --tail=50 $(docker ps -q --filter "name=SalesCRM") 2>&1 | head -100
    fi
}

cmd_enable() {
    check_docker
    echo -e "${BLUE}Enabling auto-restart for SalesCRM containers...${NC}"
    CONTAINERS=$(get_salescrm_containers)
    if [ -n "$CONTAINERS" ]; then
        docker update --restart=always $CONTAINERS
        echo -e "${GREEN}✓ Auto-restart enabled${NC}"
        echo "Containers will now start automatically when Docker starts"
    else
        echo -e "${YELLOW}No SalesCRM containers found${NC}"
    fi
}

cmd_disable() {
    check_docker
    echo -e "${BLUE}Disabling auto-restart for SalesCRM containers...${NC}"
    CONTAINERS=$(get_salescrm_containers)
    if [ -n "$CONTAINERS" ]; then
        docker update --restart=no $CONTAINERS
        echo -e "${GREEN}✓ Auto-restart disabled${NC}"
        echo "Containers will NOT start automatically"
    else
        echo -e "${YELLOW}No SalesCRM containers found${NC}"
    fi
}

cmd_clean() {
    check_docker
    echo -e "${RED}Warning: This will stop and REMOVE all SalesCRM containers!${NC}"
    read -p "Are you sure? (yes/no): " confirm
    
    if [ "$confirm" == "yes" ]; then
        echo -e "${BLUE}Removing SalesCRM containers...${NC}"
        docker rm -f $(docker ps -aq --filter "name=SalesCRM") 2>/dev/null
        echo -e "${GREEN}✓ All SalesCRM containers removed${NC}"
    else
        echo -e "${YELLOW}Operation cancelled${NC}"
    fi
}

# Main command handler
case "${1:-help}" in
    start)
        cmd_start
        ;;
    stop)
        cmd_stop
        ;;
    restart)
        cmd_restart
        ;;
    status)
        cmd_status
        ;;
    logs)
        cmd_logs "$@"
        ;;
    enable)
        cmd_enable
        ;;
    disable)
        cmd_disable
        ;;
    clean)
        cmd_clean
        ;;
    help|--help|-h|*)
        show_help
        ;;
esac
